\" min=\"0\" max=\"1\" step=\"0.01\" value=\"0\">\n                        </div>\n                        <div class=\"range-row\">\n                            <label for=\"crop-size\">裁剪范围</label>\n                            <input id=\"crop-size\" type=\"range\" name=\"crop_size\" min=\"0.2\" max=\"1\" step=\"0.01\" value=\"1\">\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <button type=\"submit\">上传本地头像</button>\n        </form>\n    </div>\n    <div class=\"card\">\n        <h2>URL 导入头像</h2>\n        <form method=\"post\">\n            <input type=\"hidden\" name=\"action\" value=\"remote_avatar\">\n            <label>资源 URL\n                <input type=\"text\" name=\"source_url\" placeholder=\"\">\n            </label>\n            <button type=\"submit\">导入头像</button>\n        </form>\n    </div>\n</div>\n<script>\n    (() => {\n        const fileInput = document.getElementById(\"avatar-file\");\n        const preview = document.getElementById(\"crop-preview\");\n        const cropLeft = document.getElementById(\"crop-left\");\n        const cropTop = document.getElementById(\"crop-top\");\n        const cropSize = document.getElementById(\"crop-size\");\n        if (!fileInput || !preview || !cropLeft || !cropTop || !cropSize) return;\n\n        const updatePreview = () => {\n            const x = Number(cropLeft.value) * 100;\n            const y = Number(cropTop.value) * 100;\n            const size = Number(cropSize.value);\n            const zoom = 1 / size;\n            preview.style.transform = `scale(${zoom})`;\n            preview.style.transformOrigin = `${x}% ${y}%`;\n        };\n\n        fileInput.addEventListener(\"change\", () => {\n            const file = fileInput.files && fileInput.files[0];\n            if (!file) return;\n            preview.src = URL.createObjectURL(file);\n            cropLeft.value = \"0\";\n            cropTop.value = \"0\";\n            cropSize.value = \"1\";\n            updatePreview();\n        });\n\n        [cropLeft, cropTop, cropSize].forEach((element) => {\n            element.addEventListener(\"input\", updatePreview);\n        });\n\n        updatePreview();\n    })();\n</script>\n\n    </div>\n    <script>\n        (() => {\n            const slides = Array.from(document.querySelectorAll(\".background-slide\"));\n            if (slides.length < 2) return;\n            let current = 0;\n            window.setInterval(() => {\n                slides[current].classList.remove(\"is-active\");\n                current = (current + 1) % slides.length;\n                slides[current].classList.add(\"is-active\");\n            }, 5000);\n        })();\n    </script>\n</body>\n</html>"}}
